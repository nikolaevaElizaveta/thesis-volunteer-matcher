# Server
PORT=3000

# Matcher service URL (used by POST /match)
# Docker backend: http://matcher:8000  |  Local dev: http://localhost:8000
MATCHER_URL=http://localhost:8000

# Tasks starting within this many hours are excluded from POST /match unless marked Urgent. 0 = disable cutoff.
# MATCHING_CUTOFF_HOURS_BEFORE_START=24

# PostgreSQL — use either DATABASE_URL OR the discrete variables below
# DATABASE_URL=postgresql://postgres:password@localhost:5432/volunteer_matcher

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_user
DATABASE_PASSWORD=
DATABASE_NAME=volunteer_matcher

# true = auto schema (dev). false = use migrations (production)
TYPEORM_SYNCHRONIZE=true

# JWT signing (min 8 chars). Required in NODE_ENV=production. Dev uses a built-in default if unset.
# Generate: openssl rand -base64 32  (use the same value as root .env when using Docker too)
# JWT_SECRET=
# JWT_EXPIRES_SEC=604800

# TypeORM CLI (npm run migration:*) loads this file — use same DATABASE_* or DATABASE_URL as the app.
# Geography columns require PostGIS: Docker Compose uses postgis/postgis; local Homebrew: brew install postgis
# Then: npm run migration:run

# Dev/demo only: if true, loads src/seed/dev-seed.json when BOTH tasks and offers tables are empty
SEED=false
