# Copy to .env in the repo root (optional). docker compose reads these for substitution.
# Defaults in docker-compose.yml match these values if you skip .env.

# --- PostgreSQL (postgres service) — image is postgis/postgis (see postgres/init/) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=volunteer_matcher
POSTGRES_PORT=5432
# Switched from plain postgres? Remove old volume once: docker compose down -v

# --- Ports on your machine ---
BACKEND_PORT=3000
MATCHER_PORT=8000
FRONTEND_PORT=3001

# --- Frontend: browser must reach backend on the host (not Docker service names) ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Backend / TypeORM (set automatically in compose via DATABASE_URL; listed for clarity) ---
# In containers, backend gets:
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/volunteer_matcher
#   MATCHER_URL=http://matcher:8000
#
# Local NestJS (no Docker): use backend/.env with DATABASE_* or DATABASE_URL=...@localhost...

# Set to false when you add migrations (production)
TYPEORM_SYNCHRONIZE=true

# Docker: compose defaults SEED=true; set SEED=false to disable. Local npm uses backend/.env SEED.
SEED=true

# Strongly recommended: same JWT_SECRET here and in backend/.env if you use Docker and local Nest interchangeably.
# Generate: openssl rand -base64 32
# JWT_SECRET=

# Backend: stop auto-matching tasks starting within this many hours (unless task is Urgent). 0 = no cutoff.
# MATCHING_CUTOFF_HOURS_BEFORE_START=24
